# Copier ce fichier en ".env" (local) et renseigner les mêmes clés dans les
# "Environment Variables" du projet Vercel pour la prod.

# Fournie par Neon (ou Supabase) après création de la base — cocher l'option
# "Pooled connection" chez Neon pour de meilleures perfs en serverless.
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/edukid?sslmode=require"

# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=""

# En local : http://localhost:3000
# En prod (Vercel) : l'URL de ton déploiement, ex. https://edukid.vercel.app
NEXTAUTH_URL="http://localhost:3000"
